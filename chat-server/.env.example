# Copy this file to .env and fill in values before running the server

# Required in production — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Server port (default: 8080)
PORT=8080

# Node environment: development | production
NODE_ENV=development

# Frontend origin allowed for CORS (default: http://localhost:5173)
ALLOWED_ORIGIN=http://localhost:5173
